{
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/src/pages/index.html" },
    { "source": "/index", "destination": "/src/pages/index.html" },
    { "source": "/category", "destination": "/src/pages/category.html" },
    { "source": "/product", "destination": "/src/pages/product.html" },
    { "source": "/cart", "destination": "/src/pages/cart.html" },
    { "source": "/admin/login", "destination": "/src/pages/admin/login.html" },
    { "source": "/admin/dashboard", "destination": "/src/pages/admin/dashboard.html" },
    { "source": "/admin/sections", "destination": "/src/pages/admin/sections.html" },
    { "source": "/admin/products", "destination": "/src/pages/admin/products.html" },
    { "source": "/css/:path*", "destination": "/src/css/:path*" },
    { "source": "/js/:path*", "destination": "/src/js/:path*" },
    { "source": "/public/:path*", "destination": "/public/:path*" },
    { "source": "/assets/:path*", "destination": "/public/assets/:path*" }
  ]
}
